# 비밀 — 절대 커밋 금지
.env

# 브라우저 로그인 세션 (쿠키 포함, 절대 커밋 금지)
.browser/

# 받은 PDF (저작권 + 용량). 폴더는 유지하고 내용만 제외
papers/*
!papers/.gitkeep

# 생성된 리뷰 카드·대시보드·그림 (각자 로컬 결과물; 팀과 공유하려면 아래 줄을 지우세요)
research/*.html
research/images/*
!research/images/.gitkeep

# python
__pycache__/
*.py[cod]
.venv/
venv/

# OS
.DS_Store
Thumbs.db
