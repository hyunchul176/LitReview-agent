# 본인 키로 채우세요. 이 파일(.env.example)은 커밋하고, .env 는 절대 커밋하지 마세요.
# 사용법: cp .env.example .env  그다음 .env 를 열어 값 입력.

# KAIST 제공 (Elsevier·ScienceDirect 본문 다운로드)
ELSEVIER_API_KEY=

# KAIST 제공 (Wiley 본문 다운로드, TDM 토큰)
WILEY_TDM_TOKEN=

# 선택 (Springer)
SPRINGER_API_KEY=

# 선택 (Semantic Scholar — 없어도 일부 호출 가능)
SEMANTIC_SCHOLAR_API_KEY=

# 키가 아님. 본인 이메일 (OpenAlex polite pool — 응답 속도/안정성용)
OPENALEX_EMAIL=
